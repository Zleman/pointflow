{
  "name": "pointflow",
  "version": "0.1.1",
  "private": false,
  "description": "React-first streaming point data core for high-volume visualization workflows.",
  "license": "MIT",
  "author": "Mudar Tayy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zleman/pointflow.git"
  },
  "homepage": "https://pointflow-docs.vercel.app",
  "bugs": {
    "url": "https://github.com/Zleman/pointflow/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./laz": {
      "types": "./dist/laz.d.ts",
      "import": "./dist/laz.js"
    },
    "./copc": {
      "types": "./dist/copc/index.d.ts",
      "import": "./dist/copc/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./e57": {
      "types": "./dist/e57.d.ts",
      "import": "./dist/e57.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:demo": "tsc -p demo/tsconfig.json --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck:demo",
    "check:unused:src": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "check:unused:demo": "tsc -p demo/tsconfig.json --noEmit --noUnusedLocals --noUnusedParameters",
    "check:unused": "npm run check:unused:src && npm run check:unused:demo",
    "build": "tsc -p tsconfig.build.json && node scripts/fix-esm-imports.mjs && node -e \"require('fs').readdirSync('src/webgpu').filter(f=>f.endsWith('.wgsl')).forEach(f=>require('fs').copyFileSync('src/webgpu/'+f,'dist/webgpu/'+f))\"",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "release:check": "npm test && npm run bench && npm run typecheck && npm run build",
    "prepublishOnly": "npm run release:check",
    "bench": "vitest run --config vitest.bench.config.ts",
    "bench:3x": "npm run bench && npm run bench && npm run bench",
    "dev:demo": "vite --config demo/vite.config.ts",
    "build:laz-inlined": "node scripts/build-laz-inlined.mjs",
    "build:demo": "vite build --config demo/vite.config.ts --outDir ../demo-dist --emptyOutDir"
  },
  "sideEffects": false,
  "peerDependencies": {
    "@react-three/drei": "^9.0.0 || ^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "three": "^0.160.0 || ^0.170.0"
  },
  "devDependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.0.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.0",
    "fast-check": "^4.6.0",
    "jsdom": "^25.0.0",
    "laz-perf": "^0.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.170.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
